.cc-gh-widget {
  position: fixed;
  bottom: 20px;
  right: 20px;
  width: 300px;
  background: #1e1e2e;
  color: #f2f2f7;
  border-radius: 10px;
  box-shadow: 0 6px 24px rgba(0, 0, 0, 0.35);
  z-index: 2147483647;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 13px;
}

.cc-gh-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 12px;
  background: #6c47ff;
  border-radius: 10px 10px 0 0;
  font-weight: 600;
  cursor: default;
}

.cc-gh-toggle {
  background: transparent;
  border: none;
  color: white;
  font-size: 16px;
  cursor: pointer;
  line-height: 1;
  padding: 0 4px;
}

.cc-gh-body {
  padding: 10px 12px;
  max-height: 70vh;
  overflow-y: auto;
}

.cc-gh-label {
  display: block;
  margin-bottom: 8px;
}

.cc-gh-label span {
  display: block;
  margin-bottom: 3px;
  color: #b8b8c8;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

.cc-gh-label input,
.cc-gh-label textarea {
  width: 100%;
  box-sizing: border-box;
  background: #2a2a3d;
  border: 1px solid #3d3d54;
  border-radius: 6px;
  color: #f2f2f7;
  padding: 6px 8px;
  font-family: inherit;
}

.cc-gh-label textarea {
  font-family: "SF Mono", Consolas, monospace;
  font-size: 11px;
  resize: vertical;
}

.cc-gh-btn {
  width: 100%;
  padding: 8px 10px;
  border-radius: 6px;
  border: none;
  font-weight: 600;
  cursor: pointer;
  margin-bottom: 8px;
}

.cc-gh-btn-primary {
  background: #6c47ff;
  color: white;
}

.cc-gh-btn-secondary {
  background: #3d3d54;
  color: #f2f2f7;
}

.cc-gh-status {
  font-size: 12px;
  color: #b8b8c8;
  min-height: 16px;
}
